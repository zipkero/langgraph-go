# langgraph-go 환경변수 샘플
#
# 사용법:
#   1) 이 파일을 .env 로 복사: cp .env.sample .env
#   2) 값을 채운다.
#   3) 라이브/e2e 테스트는 OS 환경변수를 직접 읽으므로(os.Getenv), 셸에 export 하거나
#      config.LoadEnv(".env") 를 호출하는 코드 경로에서만 .env 가 반영된다.
#      예) export ANTHROPIC_API_KEY=...   (PowerShell: $env:ANTHROPIC_API_KEY="...")
#
# .env 는 .gitignore 에 등록돼 커밋되지 않는다. 이 .env.sample 만 버전 관리한다.

# OpenAI — 기본 기준 프로바이더 (README §4).
# 챗 기본 모델 gpt-5.4-nano-2026-03-17, 임베딩 text-embedding-3-small(1536차원).
# 라이브 스모크 테스트와 Supabase 적재 통합 테스트에 필요.
OPENAI_API_KEY=

# Anthropic (Claude) — 명시 지정 대체 챗 경로(anthropic:<model>). 라이브 챗·멀티에이전트 e2e 에 필요.
ANTHROPIC_API_KEY=

# Supabase Postgres 직접 연결 문자열 — database 통합 테스트·Supabase 벡터 경로(pgx)에 필요.
# 대시보드 Connect → Session pooler URI 를 사용한다.
# 예) postgresql://postgres.xxxxx:<password>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Supabase REST 자격증명 — config 어셈블리(config.LoadEnv)가 읽는 값(선택).
# 현재 벡터 검색 경로는 DATABASE_URL 만 사용한다.
SUPABASE_URL=
SUPABASE_KEY=

# 웹 검색 (Tavily) — search 연동·통합 테스트에 필요(선택)
TAVILY_API_KEY=

# Google Drive OAuth — storage 통합 테스트에 필요(선택).
# credentials.json / token.json 파일 경로를 지정한다.
GOOGLE_DRIVE_CREDENTIALS_PATH=
GOOGLE_DRIVE_TOKEN_PATH=
