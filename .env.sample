# langgraph-go 환경변수 샘플
#
# 사용법:
#   1) 이 파일을 .env 로 복사: cp .env.sample .env
#   2) 값을 채운다.
#   3) 라이브/e2e 테스트는 OS 환경변수를 직접 읽으므로(os.Getenv), 셸에 export 하거나
#      config.LoadEnv(".env") 를 호출하는 코드 경로에서만 .env 가 반영된다.
#      예) export ANTHROPIC_API_KEY=...   (PowerShell: $env:ANTHROPIC_API_KEY="...")
#
# .env 는 .gitignore 에 등록돼 커밋되지 않는다. 이 .env.sample 만 버전 관리한다.

# 챗 모델 (Anthropic / Claude) — 라이브 챗·멀티에이전트 e2e 에 필요
ANTHROPIC_API_KEY=

# 임베딩 (OpenAI) — 현재 임베딩은 Ollama 로컬을 사용하므로 선택값
OPENAI_API_KEY=

# 웹 검색 (Tavily) — Phase 7 search 연동에 필요(선택)
TAVILY_API_KEY=

# Supabase (pgvector / database) — Phase 7 외부 연동에 필요(선택)
SUPABASE_URL=
SUPABASE_KEY=
